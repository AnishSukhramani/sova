# =========================================================
# SOVA — Environment variables template
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# =========================================================

# --- Database (Postgres runs inside Docker, hostname is "db") ---
POSTGRES_DB=sova
POSTGRES_USER=sova
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://sova:changeme_in_production@db:5432/sova

# --- Redis (runs inside Docker, hostname is "redis") ---
REDIS_URL=redis://redis:6379/0

# --- Django ---
DJANGO_SECRET_KEY=changeme_generate_a_real_50_char_random_string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- LLM providers ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# --- Observability ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=sova
SENTRY_DSN=

# --- Data source API keys (fill in as you acquire them) ---
GOOGLE_MAPS_API_KEY=
HUNTER_API_KEY=
PROXYCURL_API_KEY=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_API_KEY=
GMAIL_CREDENTIALS_PATH=/app/credentials/gmail.json
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
YELP_API_KEY=
JSEARCH_API_KEY=

# --- API authentication ---
SOVA_API_KEY=sova-dev-key-change-in-production
